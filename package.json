{
  "name": "pixel-pint-arcade",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run --config config/vitest.config.mts",
    "test:watch": "vitest --config config/vitest.config.mts",
    "test:component": "vitest run --config config/vitest.component.config.mts",
    "test:component:watch": "vitest --config config/vitest.component.config.mts",
    "test:e2e": "node tests/e2e/build-test-app.mjs && playwright test --config config/playwright.config.ts",
    "test:e2e:headed": "node tests/e2e/build-test-app.mjs && playwright test --config config/playwright.config.ts --headed",
    "test:integration": "vitest run --config config/vitest.integration.config.mts",
    "test:integration:watch": "vitest --config config/vitest.integration.config.mts",
    "test:db:up": "docker compose --env-file .env.test -f config/docker-compose.test.yml up -d",
    "test:db:migrate": "node tests/integration/migrate-test-db.mjs",
    "test:db:down": "docker compose --env-file .env.test -f config/docker-compose.test.yml down -v"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.11",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
